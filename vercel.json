{
  "version": 2,
  "buildCommand": "echo 'static site - no build needed'",
  "outputDirectory": "public",
  "functions": {
    "api/*.js": {
      "maxDuration": 15
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/admin/(.*)", "dest": "/admin/$1" },
    { "src": "/admin", "dest": "/admin/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
